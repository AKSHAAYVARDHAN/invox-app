rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function userPath(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }

    function currentUser() {
      return get(userPath(uid())).data;
    }

    function hasRole(role) {
      return signedIn()
        && exists(userPath(uid()))
        && currentUser().role == role;
    }

    function isModerator() {
      return hasRole('moderator') || hasRole('admin');
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function owns(field) {
      return signedIn() && request.resource.data[field] == uid();
    }

    function existingOwner(field) {
      return signedIn() && resource.data[field] == uid();
    }

    function protectedUserFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'uid',
        'role',
        'followerCount',
        'followingCount',
        'savedPostCount',
        'savedProjectCount',
        'savedOpportunityCount',
        'reputation',
        'createdAt'
      ]);
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && userId == uid()
        && request.resource.data.uid == uid()
        && request.resource.data.role == 'user';
      allow update: if isAdmin() || (signedIn() && userId == uid() && !protectedUserFieldsChanged());
      allow delete: if isAdmin();

      match /sparkConversations/{conversationId} {
        allow read, write: if signedIn() && userId == uid();
      }
    }

    match /posts/{postId} {
      allow read: if signedIn();
      allow create: if owns('authorId');
      allow update, delete: if existingOwner('authorId') || isModerator();
    }

    match /projects/{projectId} {
      allow read: if signedIn() && (resource.data.status == 'published' || resource.data.authorId == uid() || isModerator());
      allow create: if owns('authorId');
      allow update, delete: if existingOwner('authorId') || isModerator();
    }

    match /trendz/{trendId} {
      allow read: if signedIn();
      allow write: if isModerator();
    }

    match /communities/{communityId} {
      allow read: if signedIn();
      allow create: if owns('ownerId');
      allow update, delete: if existingOwner('ownerId') || isModerator();
    }

    match /communityMemberships/{membershipId} {
      allow read: if signedIn();
      allow create: if owns('userId');
      allow update, delete: if existingOwner('userId') || isModerator();
    }

    match /comments/{commentId} {
      allow read: if signedIn();
      allow create: if owns('authorId');
      allow update, delete: if existingOwner('authorId') || isModerator();
    }

    match /likes/{likeId} {
      allow read: if signedIn();
      allow create: if owns('userId');
      allow delete: if existingOwner('userId') || isModerator();
      allow update: if false;
    }

    match /bookmarks/{bookmarkId} {
      allow read: if signedIn() && resource.data.userId == uid();
      allow create: if owns('userId');
      allow delete: if existingOwner('userId') || isModerator();
      allow update: if false;
    }

    match /follows/{followId} {
      allow read: if signedIn();
      allow create: if owns('followerId');
      allow delete: if existingOwner('followerId') || isModerator();
      allow update: if false;
    }

    match /applications/{applicationId} {
      allow read: if signedIn() && (resource.data.applicantId == uid() || resource.data.ownerId == uid() || isModerator());
      allow create: if owns('applicantId');
      allow update: if signedIn() && (resource.data.applicantId == uid() || resource.data.ownerId == uid() || isModerator());
      allow delete: if isModerator();
    }

    match /savedOpportunities/{savedId} {
      allow read: if signedIn() && resource.data.userId == uid();
      allow create: if owns('userId');
      allow delete: if existingOwner('userId') || isModerator();
      allow update: if false;
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if signedIn() && resource.data.recipientId == uid();
      allow create: if signedIn() && request.resource.data.recipientId is string;
    }

    match /reports/{reportId} {
      allow read, update, delete: if isModerator();
      allow create: if owns('reporterId');
    }

    match /messages/{conversationId} {
      allow read, update, delete: if signedIn() && (uid() in resource.data.participants || isModerator());
      allow create: if signedIn() && uid() in request.resource.data.participants;

      match /messages/{messageId} {
        allow read: if signedIn()
          && (uid() in get(/databases/$(database)/documents/messages/$(conversationId)).data.participants || isModerator());
        allow create: if signedIn()
          && request.resource.data.senderId == uid()
          && uid() in get(/databases/$(database)/documents/messages/$(conversationId)).data.participants;
        allow update, delete: if signedIn()
          && (resource.data.senderId == uid() || isModerator());
      }
    }
  }
}
